{
  "name": "@koppajs/koppajs-core",
  "version": "3.0.6",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/koppajs/koppajs-core"
  },
  "description": "Koppa.js is a lightweight, high-performance frontend framework designed for building modern web applications without relying on a virtual DOM. It offers a modular architecture, reactivity, and seamless integration with TypeScript and Vite.",
  "keywords": [
    "koppa",
    "koppajs",
    "koppa.js",
    "frontend",
    "framework",
    "ui-framework",
    "typescript",
    "vite",
    "reactivity",
    "single-file-components",
    "modular",
    "lightweight",
    "high-performance",
    "web-development",
    "javascript"
  ],
  "author": "Bastian Bensch",
  "license": "Apache-2.0",
  "homepage": "https://koppajs.org",
  "scripts": {
    "prepare": "husky",
    "generate:types": "tsc --project tsconfig.types.json",
    "copy:dts": "node scripts/copy-dts.js",
    "clean": "rimraf dist coverage",
    "deepclean": "rimraf node_modules dist",
    "nuke": "rimraf node_modules dist",
    "nuke:all": "rimraf node_modules dist pnpm-lock.yaml",
    "typecheck:src": "tsc --project tsconfig.json",
    "typecheck:test": "tsc --project tsconfig.test.json",
    "typecheck": "pnpm run typecheck:src && pnpm run typecheck:test",
    "prebuild": "rimraf dist",
    "build": "pnpm run typecheck:src && vite build && pnpm generate:types && pnpm run copy:dts",
    "rebuild": "pnpm run clean && pnpm run build",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run check:docs && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:ci",
    "validate": "pnpm run check:docs && pnpm run check && pnpm run build",
    "check:docs": "node scripts/check-doc-contract.mjs"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "terser": "^5.44.1",
    "typescript": "^5.7.2",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "fflate": "^0.8.2"
  },
  "overrides": {
    "glob": "^11.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "private": false
}
