{
  "name": "@koppajs/koppajs-core",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/koppajs/koppajs-core"
  },
  "description": "Koppa.js is a lightweight, high-performance frontend framework designed for building modern web applications without relying on a virtual DOM. It offers a modular architecture, reactivity, and seamless integration with TypeScript and Vite.",
  "keywords": [
    "koppa",
    "koppajs",
    "koppa.js",
    "frontend",
    "framework",
    "ui-framework",
    "typescript",
    "vite",
    "reactivity",
    "single-file-components",
    "modular",
    "lightweight",
    "high-performance",
    "web-development",
    "javascript"
  ],
  "author": "Bastian Bensch",
  "license": "MIT",
  "homepage": "https://koppajs.org",
  "scripts": {
    "clean": "rimraf node_modules dist pnpm-lock.yaml",
    "typecheck": "tsc --project config/tsconfig.json",
    "build": "pnpm run typecheck && vite build --config config/vite.config.ts",
    "postbuild": "node scripts/postbuild.js",
    "rebuild": "pnpm run clean && pnpm run build",
    "test": "vitest --config config/vitest.config.ts --run",
    "test:coverage": "vitest --config config/vitest.config.ts --coverage",
    "test:watch": "vitest --config config/vitest.config.ts --watch",
    "lint:scripts": "pnpm eslint . --config config/eslint.config.js --fix",
    "lint:styles": "stylelint '**/*.{css,scss}' --config config/stylelint.config.js --fix || true",
    "lint": "pnpm run lint:scripts && pnpm run lint:styles",
    "format:scripts": "prettier --ignore-path config/.prettierignore --config config/prettier.config.js --write .",
    "format:styles": "stylelint '**/*.{css,scss}' --config config/stylelint.config.js --fix || true",
    "format": "pnpm run format:scripts && pnpm run format:styles",
    "prepare": "husky",
    "list-structure": "git ls-files > ---project-structure",
    "dump-code": "node scripts/dump-code.js",
    "analyze-code": "node scripts/analyze-code.js",
    "build:dts": "dts-bundle-generator --project config/tsconfig.json --out-file dist/index.d.ts src/index.ts"
  },
  "peerDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "commitlint": "^19.8.0",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "stylelint": "^16.15.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended": "^14.0.1",
    "stylelint-config-sass-guidelines": "^12.1.0",
    "stylelint-order": "^6.0.4",
    "terser": "^5.16.1",
    "ts-node": "^10.9.1",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "glob": "^11.0.0"
  }
}
