#!/usr/bin/env bash

echo "🚀 Running pre-commit checks..."

# Ensure that pnpm is installed
if ! command -v pnpm &> /dev/null; then
  echo "❌ Error: pnpm is not installed!" >&2
  exit 1
fi

# Get staged files that match the relevant extensions
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|tsx|vue|json|scss|css|md)$' || true)

# If no relevant files are staged, exit early
if [ -z "$STAGED_FILES" ]; then
  echo "✅ No relevant staged files found. Skipping pre-commit hooks."
  exit 0
fi

# Format only staged files
echo "🖌 Running Prettier on staged files..."
echo "$STAGED_FILES" | xargs pnpm prettier --write
echo "$STAGED_FILES" | xargs git add  # Re-stage formatted files

# Lint only staged files
echo "🔍 Running ESLint on staged files..."
echo "$STAGED_FILES" | xargs pnpm eslint --fix
if [ $? -ne 0 ]; then
  echo "❌ Linting failed! Commit aborted."
  exit 1
fi
echo "$STAGED_FILES" | xargs git add  # Re-stage linted files

# Run tests only if relevant files are staged
echo "🧪 Running tests..."
pnpm test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed! Commit aborted."
  exit 1
fi

echo "✅ All checks passed! Proceeding with commit."
exit 0
