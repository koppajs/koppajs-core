#!/usr/bin/env bash
# Run lint-staged for staged files only

echo "🚀 Running pre-commit checks (lint-staged)..."

# pnpm must be installed
if ! command -v pnpm >/dev/null 2>&1; then
  echo "❌ Error: pnpm is not installed!" >&2
  exit 1
fi

pnpm lint-staged --config config/lint-staged.config.js
STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo "❌ lint-staged checks failed. Commit aborted."
  exit 1
fi

echo "✅ All lint-staged checks passed!"
exit 0
