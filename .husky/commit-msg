#!/usr/bin/env bash
export LC_ALL=en_US.UTF-8

echo "рџљЂ Running commit message validation..."

# Check if `pnpm` is installed
if ! command -v pnpm &> /dev/null; then
  echo "вќЊ Error: pnpm is not installed!" >&2
  exit 1
fi

# Read commit message
COMMIT_MSG=$(cat "$1")

# вњ… Skip system-generated commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|Release|chore\(release\)|fixup!|squash!)"; then
  echo "в„№пёЏ Detected system commit. Skipping validation."
  exit 0
fi

# 1пёЏвѓЈ Capitalize first letter after type
CORRECTED_MSG=$(echo "$COMMIT_MSG" | awk -F': ' '{
  if (NF > 1) {
    type=$1;
    sub("^.", toupper(substr($2,1,1)), $2);
    print type": "$2
  } else {
    print $0
  }
}')
echo "$CORRECTED_MSG" > "$1"
COMMIT_MSG="$CORRECTED_MSG"

# 2пёЏвѓЈ Separate header, body, footer
HEADER=$(echo "$COMMIT_MSG" | head -n1)
BODY_AND_FOOTER=$(echo "$COMMIT_MSG" | tail -n +2)

if echo "$BODY_AND_FOOTER" | grep -qE "^[A-Za-z0-9-]+: .*$"; then
  BODY=$(echo "$BODY_AND_FOOTER" | sed -E '/^[A-Za-z0-9-]+: .*$/,$d')
  FOOTER=$(echo "$BODY_AND_FOOTER" | grep -E "^[A-Za-z0-9-]+: .*")
else
  BODY="$BODY_AND_FOOTER"
  FOOTER=""
fi

# 3пёЏвѓЈ Fix sentence casing in body
if [ -n "$BODY" ]; then
  FIXED_BODY=$(echo "$BODY" | awk '{
    gsub(/([.!?])\s*\n\s*([a-z])/, "\\1\n\n\\U\\2", $0);
    gsub(/([.!?]) ([a-z])/, "\\1 \\U\\2", $0);
    print;
  }')
else
  FIXED_BODY=""
fi

# 4пёЏвѓЈ Validate header length (strict)
HEADER_TEXT=$(echo "$HEADER" | cut -d " " -f2-)
HEADER_LENGTH=${#HEADER_TEXT}
if [ "$HEADER_LENGTH" -gt 72 ]; then
  echo "вќЊ Commit header too long! Max 72 characters allowed."
  exit 1
fi

# 5пёЏвѓЈ Auto-wrap body (72 char soft limit)
WRAPPED_BODY=$(echo "$FIXED_BODY" | fold -s -w 72)

# 6пёЏвѓЈ Auto-wrap footer
WRAPPED_FOOTER=$(echo "$FOOTER" | fold -s -w 72)

# 7пёЏвѓЈ Run commitlint
pnpm commitlint --config ./config/commitlint.config.js --edit "$1"
STATUS=$?
if [ $STATUS -ne 0 ]; then
  echo "вќЊ Commitlint validation failed."
  exit 1
fi

# 8пёЏвѓЈ Inject Gitmoji (avoid duplicates)
case "$HEADER" in
  feat:*)      PREFIX="вњЁ" ;;
  fix:*)       PREFIX="рџђ›" ;;
  docs:*)      PREFIX="рџ“ќ" ;;
  refactor:*)  PREFIX="в™»пёЏ" ;;
  test:*)      PREFIX="вњ…" ;;
  chore:*)     PREFIX="рџ§№" ;;
  *)           PREFIX=""   ;;
esac

if [ -n "$PREFIX" ]; then
  CLEAN_HEADER=$(echo "$HEADER" | sed -E "s/^([^:]+):[^a-zA-Z0-9]*\s*(.*)/\1: $PREFIX \2/")
else
  CLEAN_HEADER="$HEADER"
fi

# рџ”љ Write final message
echo -e "$CLEAN_HEADER\n\n$WRAPPED_BODY\n\n$WRAPPED_FOOTER" > "$1"

echo "вњ… Commit message is valid!"
exit 0
