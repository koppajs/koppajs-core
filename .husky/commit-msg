#!/usr/bin/env bash

echo "🚀 Running commit message validation..."

# Check if `pnpm` is installed
if ! command -v pnpm &> /dev/null; then
  echo "❌ Error: pnpm is not installed!" >&2
  exit 1
fi

# Read commit message
COMMIT_MSG=$(cat "$1")

# ✅ Skip system-generated commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|Release|chore\(release\)|fixup!|squash!)"; then
  echo "ℹ️ Detected system commit. Skipping validation."
  exit 0
fi

# 1️⃣ Capitalize first letter after type
CORRECTED_MSG=$(echo "$COMMIT_MSG" | awk -F': ' '{
  if (NF > 1) {
    type=$1;
    sub("^.", toupper(substr($2,1,1)), $2);
    print type": "$2
  } else {
    print $0
  }
}')
echo "$CORRECTED_MSG" > "$1"
COMMIT_MSG="$CORRECTED_MSG"

# 2️⃣ Separate header, body, footer
HEADER=$(echo "$COMMIT_MSG" | head -n1)
BODY_AND_FOOTER=$(echo "$COMMIT_MSG" | tail -n +2)

if echo "$BODY_AND_FOOTER" | grep -qE "^[A-Za-z0-9-]+: .*$"; then
  BODY=$(echo "$BODY_AND_FOOTER" | sed -E '/^[A-Za-z0-9-]+: .*$/,$d')
  FOOTER=$(echo "$BODY_AND_FOOTER" | grep -E "^[A-Za-z0-9-]+: .*")
else
  BODY="$BODY_AND_FOOTER"
  FOOTER=""
fi

# 3️⃣ Fix sentence casing in body
if [ -n "$BODY" ]; then
  FIXED_BODY=$(echo "$BODY" | awk '{
    gsub(/([.!?])\s*\n\s*([a-z])/, "\\1\n\n\\U\\2", $0);
    gsub(/([.!?]) ([a-z])/, "\\1 \\U\\2", $0);
    print;
  }')
else
  FIXED_BODY=""
fi

# 4️⃣ Validate header length (strict)
HEADER_TEXT=$(echo "$HEADER" | cut -d " " -f2-)
HEADER_LENGTH=${#HEADER_TEXT}
if [ "$HEADER_LENGTH" -gt 72 ]; then
  echo "❌ Commit header too long! Max 72 characters allowed."
  exit 1
fi

# 5️⃣ Auto-wrap body (72 char soft limit)
WRAPPED_BODY=$(echo "$FIXED_BODY" | fold -s -w 72)

# 6️⃣ Auto-wrap footer
WRAPPED_FOOTER=$(echo "$FOOTER" | fold -s -w 72)

# 7️⃣ Run commitlint
pnpm commitlint --config ./config/commitlint.config.js --edit "$1"
STATUS=$?
if [ $STATUS -ne 0 ]; then
  echo "❌ Commitlint validation failed."
  exit 1
fi

# 8️⃣ Inject Gitmoji (avoid duplicates)
case "$HEADER" in
  feat:*)      PREFIX="✨" ;;
  fix:*)       PREFIX="🐛" ;;
  docs:*)      PREFIX="📝" ;;
  refactor:*)  PREFIX="♻️" ;;
  test:*)      PREFIX="✅" ;;
  chore:*)     PREFIX="🧹" ;;
  *)           PREFIX=""   ;;
esac

if [ -n "$PREFIX" ]; then
  CLEAN_HEADER=$(echo "$HEADER" | sed -E "s/^([^:]+):[^a-zA-Z0-9]*\s*(.*)/\1: $PREFIX \2/")
else
  CLEAN_HEADER="$HEADER"
fi

# 🔚 Write final message
echo -e "$CLEAN_HEADER\n\n$WRAPPED_BODY\n\n$WRAPPED_FOOTER" > "$1"

echo "✅ Commit message is valid!"
exit 0
