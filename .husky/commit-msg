#!/usr/bin/env sh
set -eu

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required for the commit-msg hook." >&2
  exit 1
fi

commit_msg_file=$1

if grep -qE '^(Merge|Revert|fixup!|squash!)' "$commit_msg_file"; then
  exit 0
fi

pnpm exec commitlint --config commitlint.config.mjs --edit "$commit_msg_file"
